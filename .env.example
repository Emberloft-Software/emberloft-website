# Google Analytics 4 measurement ID (Admin > Data Streams > your stream)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console HTML tag verification code (Settings > Ownership verification > HTML tag, the content="..." value only)
NEXT_PUBLIC_GSC_VERIFICATION=

# Google reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
